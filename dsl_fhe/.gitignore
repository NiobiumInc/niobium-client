__pycache__/
*.pyc

# Generated C++ + build artifacts (regenerated by `make`; never checked in)
examples/*/nb_out/

# Pipeline runtime data (datasets, keys, encrypted files, I/O)
examples/*/datasets/
examples/*/io/

# Cooperative record/replay program directories created at run time
examples/*/*_workload_*/
examples/*/fhetch_driver_source_*/

# Large pre-generated input fixtures (not needed by the self-contained build)
examples/fhe-NetworkMonitor/Mirai_Workload_Inputs/

# Stub model data / weights — generated at build time; real data is opt-in
examples/ml-inference-fhe/data/*.bin
examples/fhe-NetworkMonitor/assets/models/*.bin
examples/fhe-NetworkMonitor/assets/datasets/*.bin

# replay-integrity snapshots (tools/verify_replay_integrity.py)
.*.manifest.json
